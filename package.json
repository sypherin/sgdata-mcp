{
  "name": "@altronis/sgdata-mcp",
  "version": "0.3.2",
  "description": "Comprehensive Singapore government data MCP server — ACRA, HDB, URA, Singstat, MOM, IRAS, and more. Built by Altronis.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sgdata-mcp": "dist/mcp-server.js",
    "sgdata-cli": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./tools": {
      "import": "./dist/tools/index.js",
      "types": "./dist/tools/index.d.ts"
    },
    "./datasets": {
      "import": "./dist/datasets/index.js",
      "types": "./dist/datasets/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/mcp-server.ts",
    "cli": "tsx src/cli.ts",
    "test:smoke": "tsx test/smoke.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "singapore",
    "data.gov.sg",
    "acra",
    "hdb",
    "ura",
    "singstat",
    "open-data",
    "altronis",
    "visualization",
    "sparkline",
    "cli"
  ],
  "author": "Altronis <hello@altronis.sg> (https://altronis.sg)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sypherin/sgdata-mcp"
  },
  "homepage": "https://altronis.sg",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.3.0",
    "csv-parse": "^5.5.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
